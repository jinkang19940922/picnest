PICNEST_SECRET_KEY=your-secret-key-here
PICNEST_DEBUG=false
PICNEST_BASE_URL=http://localhost:8080

# 数据库
PICNEST_DB_PATH=./data/picnest.db

# 存储
PICNEST_UPLOAD_PATH=./data/images
PICNEST_MAX_FILE_SIZE=52428800

# 水印
PICNEST_WATERMARK_ENABLED=false
PICNEST_WATERMARK_TEXT=PicNest

# 存储配额 (MB)
PICNEST_DEFAULT_QUOTA=5120